{
    "author": "Ragaeeb Haq",
    "dependencies": {},
    "description": "Finds the fastest download speed from a set of urls.",
    "devDependencies": {
        "@biomejs/biome": "^2.3.5",
        "@types/bun": "^1.3.2",
        "@types/node": "^24.10.1",
        "semantic-release": "^25.0.2",
        "tsdown": "^0.16.4",
        "typescript": "^5.9.3"
    },
    "engines": {
        "bun": ">=1.2.11",
        "node": ">=22.0.0"
    },
    "exports": {
        ".": "./dist/index.js"
    },
    "files": [
        "dist"
    ],
    "keywords": [
        "fast",
        "nodejs",
        "bun",
        "download",
        "downloading"
    ],
    "license": "MIT",
    "main": "./dist/index.js",
    "name": "rabbito",
    "repository": {
        "type": "git",
        "url": "https://github.com/ragaeeb/rabbito.git"
    },
    "scripts": {
        "build": "tsdown --config tsdown.config.ts",
        "format": "biome format --write .",
        "lint": "biome lint .",
        "typecheck": "tsc --noEmit"
    },
    "source": "src/index.ts",
    "type": "module",
    "types": "dist/index.d.ts",
    "version": "1.0.0"
